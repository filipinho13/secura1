# Configuration ERP Secura Protect

# Base de données MongoDB
MONGO_URL=mongodb://localhost:27017
DB_NAME=secura_erp

# Sécurité JWT
SECRET_KEY=changez-cette-cle-en-production-utilisez-une-cle-forte

# Environnement
ENVIRONMENT=production

# CORS (si nécessaire)
ALLOWED_ORIGINS=https://votre-domaine.com,https://www.votre-domaine.com